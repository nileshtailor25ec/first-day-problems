#include <iostream>
using namespace std;
int main() 
{
    float p,r,t, si;
    cout << "enter principal amount: ";
    cin >> p;
    cout << "enter rate of interest: ";
    cin >> r;
    cout << "enter time(in years): ";
    cin >> t;
    si=(p * r * t) / 100;
    cout << "Simple Interest is: " << si << endl;
    return 0;
}

